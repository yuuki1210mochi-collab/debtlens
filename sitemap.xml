<!-- Panels -->
<main style="max-width:var(--max-w);margin:16px auto;padding:0 16px">

  <!-- ═══ TAB 1: リボ払い ═══ -->
  <div class="tab-panel fade-in" id="panel-ribo">
    <div class="company-search" style="position:relative">
      <div class="search-bar">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input placeholder="会社名で検索（例：楽天、アコム）">
      </div>
      <div class="search-dropdown" style="display:none"></div>
    </div>

    <div class="seg-ctrl" style="margin-bottom:16px">
      <button class="seg-btn active" data-method="ganri" onclick="this.parentElement.querySelectorAll('.seg-btn').forEach(b=>b.classList.remove('active'));this.classList.add('active');calculate()">元利定額</button>
      <button class="seg-btn" data-method="gankin" onclick="this.parentElement.querySelectorAll('.seg-btn').forEach(b=>b.classList.remove('active'));this.classList.add('active');calculate()">元金定額</button>
      <button class="seg-btn" data-method="slide" onclick="this.parentElement.querySelectorAll('.seg-btn').forEach(b=>b.classList.remove('active'));this.classList.add('active');calculate()">残高スライド</button>
    </div>

    <div class="grid-2" style="margin-bottom:16px">
      <div class="slider-group">
        <div class="row"><label>利用残高</label><div>¥ <input type="number" class="num-input" data-field="balance" value="300000" min="10000" max="5000000" step="10000"></div></div>
        <input type="range" data-slider="balance" min="10000" max="5000000" step="10000" value="300000">
      </div>
      <div class="slider-group">
        <div class="row"><label>毎月返済額</label><div>¥ <input type="number" class="num-input" data-field="monthly" value="10000" min="1000" max="200000" step="1000"></div></div>
        <input type="range" data-slider="monthly" min="1000" max="200000" step="1000" value="10000">
      </div>
      <div class="slider-group">
        <div class="row"><label>年率</label><div><input type="number" class="num-input" data-field="rate" value="15.0" min="1" max="20" step="0.1"> %</div></div>
        <input type="range" data-slider="rate" min="1" max="20" step="0.1" value="15.0">
      </div>
      <div class="slider-group">
        <label>返済開始月</label>
        <input type="month" data-field="start-date" style="padding:8px 12px;border-radius:var(--radius-sm);border:1px solid var(--c-gray-200);background:var(--c-gray-50);font-size:14px;outline:none;color:var(--c-gray-800);width:100%">
      </div>
    </div>

    <div style="display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap">
      <button onclick="toggleReverse()" style="padding:6px 14px;border-radius:var(--radius-xs);border:1px solid var(--c-gray-200);background:#fff;cursor:pointer;font-size:12px;color:var(--c-gray-600)">🔄 逆算モード</button>
    </div>

